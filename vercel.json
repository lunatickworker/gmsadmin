{
  "redirects": [
    {
      "source": "/admin",
      "destination": "https://gmsadmin.vercel.app",
      "permanent": false
    },
    {
      "source": "/admin/:path*",
      "destination": "https://gmsadmin.vercel.app/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}